---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

export const prerender = true;

const aboutPage = await getEntry('pages', 'about');
const Content = aboutPage ? (await aboutPage.render()).Content : null;

const title = aboutPage?.data?.title || '关于 OpenClaude';
const description = aboutPage?.data?.description || '致力于打造极速、极简、极美的现代化文档与博客框架。';
---

<Layout title={title} description={description}>
  <div class="bg-claude-warm py-12 md:py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-claude-text mb-6">{title}</h1>
      <p class="text-xl text-claude-text-light max-w-2xl mx-auto">
        {description}
      </p>
    </div>
  </div>
  
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="prose prose-lg max-w-none text-gray-700">
      {Content ? <Content /> : <p>未找到关于页面内容。</p>}
    </div>
  </div>
</Layout>
