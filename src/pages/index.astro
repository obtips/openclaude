---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'
import TutorialCard from '../components/TutorialCard.astro'
import BlogCard from '../components/BlogCard.astro'

// 获取最新教程
const zhTutorials = await getCollection('tutorial', ({ data }) => data.draft !== true)

// 按日期排序，取前 6 篇
const latestTutorials = [...zhTutorials]
  .sort((a, b) => (b.data.date?.getTime() || 0) - (a.data.date?.getTime() || 0))
  .slice(0, 6)

// 获取最新博客文章
const blogPosts = await getCollection('blog', ({ data }) => data.draft !== true)
const latestBlogs = [...blogPosts]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)

const features = [
  {
    title: '艺术教程',
    description: '从入门到精通，全面了解印象派绘画技巧',
    link: '/tutorial/',
  },
  {
    title: '名作赏析',
    description: '深度解读莫奈、雷诺阿等大师的经典作品',
    link: '/blog/',
  },
  {
    title: '艺术之旅',
    description: '探索印象派发源地和博物馆参观指南',
    link: '#',
  },
]
---

<Layout>
  <!-- Hero Section -->
  <section class="border-b border-claude-border relative overflow-hidden" style="background: linear-gradient(135deg, #FAFAF6 0%, #F5F0E8 50%, #FAF8F0 100%);">
    <!-- 康定斯基风格色块装饰 -->
    <div class="absolute inset-0 pointer-events-none">
      <!-- 左上黄色色块 -->
      <div class="absolute top-0 left-0 w-48 h-48 opacity-20">
        <svg viewBox="0 0 200 200" class="w-full h-full">
          <circle cx="100" cy="100" r="80" fill="var(--kandinsky-yellow)"/>
        </svg>
      </div>
      <!-- 右上蓝色色块 -->
      <div class="absolute top-0 right-0 w-40 h-40 opacity-15">
        <svg viewBox="0 0 160 160" class="w-full h-full">
          <polygon points="80,20 140,140 20,140" fill="var(--kandinsky-blue)"/>
        </svg>
      </div>
      <!-- 左下红色线条 -->
      <svg class="absolute bottom-20 left-10 w-32 h-32 opacity-25" viewBox="0 0 120 120">
        <line x1="20" y1="60" x2="100" y2="60" stroke="var(--kandinsky-red)" stroke-width="3"/>
        <circle cx="60" cy="60" r="6" fill="var(--kandinsky-black)"/>
        <circle cx="30" cy="40" r="3" fill="var(--kandinsky-yellow)"/>
        <circle cx="90" cy="80" r="4" fill="var(--kandinsky-blue)"/>
      </svg>
      <!-- 右下几何组合 -->
      <svg class="absolute bottom-10 right-20 w-36 h-36 opacity-20" viewBox="0 0 140 140">
        <rect x="20" y="20" width="60" height="60" fill="none" stroke="var(--kandinsky-yellow)" stroke-width="2" transform="rotate(30 50 50)"/>
        <circle cx="110" cy="50" r="25" fill="none" stroke="var(--kandinsky-blue)" stroke-width="2"/>
        <line x1="50" y1="100" x2="130" y2="100" stroke="var(--kandinsky-red)" stroke-width="2"/>
      </svg>
      <!-- 漂散光效 -->
      <div class="absolute top-1/4 left-1/4 w-64 h-64 rounded-full" style="background: radial-gradient(circle, rgba(255,199,44,0.15) 0%, transparent 70%);"></div>
      <div class="absolute bottom-1/4 right-1/4 w-72 h-72 rounded-full" style="background: radial-gradient(circle, rgba(74,144,217,0.12) 0%, transparent 70%);"></div>
    </div>

    <div class="max-w-4xl mx-auto px-4 py-24 md:py-32 relative">
      <div class="text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 tracking-tight">
          OpenClaude
        </h1>
        <p class="text-xl md:text-2xl text-claude-text-light max-w-2xl mx-auto mb-8">
          探索光与色彩的艺术革命
        </p>
        <p class="text-base text-claude-text-light/70 max-w-xl mx-auto mb-10">
          走进 Claude Monet 和印象派大师的艺术世界，感受光与色的永恒魅力
        </p>
        <div class="flex justify-center gap-4">
          <a href="/tutorial/" class="btn-primary">
            开始探索
          </a>
          <a href="/about" class="btn-secondary">
            了解更多
          </a>
        </div>
      </div>
    </div>

    <!-- 底部装饰线条 -->
    <div class="absolute bottom-0 left-0 right-0 h-px">
      <div class="flex">
        <div class="h-px w-1/3" style="background: var(--kandinsky-yellow);"></div>
        <div class="h-px w-1/3" style="background: var(--kandinsky-blue);"></div>
        <div class="h-px w-1/3" style="background: var(--kandinsky-red);"></div>
      </div>
    </div>
  </section>

  <!-- Features with decorative background -->
  <section class="py-20 md:py-28 relative overflow-hidden">
    <!-- 背景装饰 -->
    <div class="absolute inset-0 pointer-events-none opacity-10">
      <svg class="absolute top-10 right-10 w-24 h-24" viewBox="0 0 96 96">
        <circle cx="48" cy="48" r="40" fill="none" stroke="var(--kandinsky-yellow)" stroke-width="2"/>
        <circle cx="48" cy="48" r="20" fill="none" stroke="var(--kandinsky-blue)" stroke-width="2"/>
      </svg>
      <svg class="absolute bottom-10 left-10 w-20 h-20" viewBox="0 0 80 80">
        <line x1="10" y1="40" x2="70" y2="40" stroke="var(--kandinsky-red)" stroke-width="2"/>
        <line x1="40" y1="10" x2="40" y2="70" stroke="var(--kandinsky-blue)" stroke-width="2"/>
      </svg>
    </div>

    <div class="max-w-6xl mx-auto px-4 relative">
      <div class="grid md:grid-cols-3 gap-8">
        {features.map((feature, index) => (
          <a href={feature.link} class="card text-center block relative overflow-hidden group">
            <!-- 卡片内装饰 -->
            <div class="absolute top-0 right-0 w-16 h-16 opacity-10">
              <svg viewBox="0 0 64 64" class="w-full h-full">
                {index === 0 && <circle cx="32" cy="32" r="24" fill="none" stroke="var(--kandinsky-yellow)" stroke-width="1.5"/>}
                {index === 1 && <polygon points="32,12 52,52 12,52" fill="none" stroke="var(--kandinsky-blue)" stroke-width="1.5"/>}
                {index === 2 && <rect x="14" y="14" width="36" height="36" fill="none" stroke="var(--kandinsky-red)" stroke-width="1.5" transform="rotate(20 32 32)"/>}
              </svg>
            </div>
            <h3 class="text-lg mb-2 relative">{feature.title}</h3>
            <p class="text-claude-text-light text-sm">{feature.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Tutorials -->
  <section class="py-20 md:py-28 bg-claude-warm relative">
    <!-- 装饰 -->
    <div class="absolute inset-0 pointer-events-none">
      <svg class="absolute top-1/2 right-10 w-20 h-20 opacity-10" viewBox="0 0 80 80">
        <circle cx="40" cy="40" r="30" fill="var(--kandinsky-yellow)" opacity="0.3"/>
        <line x1="40" y1="5" x2="40" y2="75" stroke="var(--kandinsky-blue)" stroke-width="2"/>
      </svg>
    </div>

    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">最新教程</h2>
        <p class="text-claude-text-light">探索印象派绘画技巧与艺术理论</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {latestTutorials.map(tutorial => (
          <TutorialCard
            title={tutorial.data.title}
            description={tutorial.data.description}
            difficulty={tutorial.data.difficulty}
            tags={tutorial.data.tags}
            slug={tutorial.slug}
            lang="zh"
          />
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/tutorial/" class="btn-secondary">
          查看全部教程
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Blogs -->
  <section class="py-20 md:py-28 relative">
    <!-- 装饰 -->
    <div class="absolute inset-0 pointer-events-none">
      <svg class="absolute top-20 left-10 w-24 h-24 opacity-10" viewBox="0 0 96 96">
        <polygon points="48,16 80,80 16,80" fill="var(--kandinsky-red)" opacity="0.2"/>
        <circle cx="48" cy="48" r="8" fill="var(--kandinsky-yellow)"/>
      </svg>
    </div>

    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">最新文章</h2>
        <p class="text-claude-text-light">阅读印象派艺术的深度见解</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {latestBlogs.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            author={post.data.author}
            tags={post.data.tags}
            category={post.data.category}
            slug={post.slug}
            featured={post.data.featured}
          />
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/blog/" class="btn-secondary">
          查看全部文章
        </a>
      </div>
    </div>
  </section>

  <!-- Quote Section with rich decoration -->
  <section class="py-20 md:py-28 relative overflow-hidden" style="background: linear-gradient(135deg, #FFFBF0 0%, #F0F5FA 50%, #FFF5F0 100%);">
    <!-- 康定斯基风格装饰 -->
    <div class="absolute inset-0 pointer-events-none">
      <svg class="absolute top-10 left-10 w-32 h-32 opacity-15" viewBox="0 0 128 128">
        <circle cx="64" cy="64" r="50" fill="none" stroke="var(--kandinsky-yellow)" stroke-width="2"/>
        <line x1="64" y1="10" x2="64" y2="118" stroke="var(--kandinsky-blue)" stroke-width="2"/>
        <line x1="10" y1="64" x2="118" y2="64" stroke="var(--kandinsky-red)" stroke-width="2"/>
      </svg>
      <svg class="absolute bottom-10 right-10 w-28 h-28 opacity-15" viewBox="0 0 112 112">
        <polygon points="56,16 96,96 16,96" fill="none" stroke="var(--kandinsky-blue)" stroke-width="2"/>
        <circle cx="56" cy="56" r="10" fill="var(--kandinsky-red)"/>
      </svg>
      <!-- 光效 -->
      <div class="absolute top-1/3 left-1/4 w-48 h-48 rounded-full" style="background: radial-gradient(circle, rgba(255,199,44,0.1) 0%, transparent 70%);"></div>
      <div class="absolute bottom-1/4 right-1/4 w-56 h-56 rounded-full" style="background: radial-gradient(circle, rgba(232,93,76,0.08) 0%, transparent 70%);"></div>
    </div>

    <div class="max-w-3xl mx-auto px-4 text-center relative">
      <svg class="w-10 h-10 mx-auto mb-6 text-claude-accent/20" fill="currentColor" viewBox="0 0 24 24">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
      </svg>
      <blockquote class="text-xl md:text-2xl text-claude-text mb-4 leading-relaxed">
        我一生都在追求不可能的事：描绘空气中的光。
      </blockquote>
      <cite class="text-claude-text-light text-sm">Claude Monet</cite>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">加入艺术之旅</h2>
      <p class="text-xl text-claude-text-light mb-10">
        印象派不仅是艺术史上的一个运动，更是一种观看世界的方式
      </p>
      <div class="flex justify-center gap-4">
        <a href="/tutorial/" class="btn-primary">
          开始学习
        </a>
        <a href="/blog/" class="btn-secondary">
          阅读文章
        </a>
      </div>
    </div>
  </section>
</Layout>
