---
import Layout from '../../../layouts/Layout.astro'
import { getCollection } from 'astro:content'
import BlogCard from '../../../components/BlogCard.astro'

export const prerender = true

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true)

const sortedPosts = [...allPosts].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
)

const featuredPosts = sortedPosts.filter(post => post.data.featured)
const regularPosts = sortedPosts.filter(post => !post.data.featured)

const categories = [...new Set(allPosts.map(post => post.data.category))]
---

<Layout title="Blog - OpenClaude" description="OpenClaude blog posts" lang="en">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Blog</h1>
      <p class="text-xl text-claude-text-light">
        Sharing tech insights, product updates, and community stories
      </p>
    </div>

    <div class="mb-8 flex flex-wrap gap-4 justify-center">
      <div class="flex flex-wrap gap-2">
        <span class="text-sm font-medium text-claude-text-light">Categories:</span>
        {categories.map(cat => (
          <a
            href={`?category=${cat}`}
            class="px-3 py-1 text-sm rounded-full bg-claude-warm hover:bg-claude-accent transition-colors"
          >
            {cat}
          </a>
        ))}
      </div>
    </div>

    {featuredPosts.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <span class="text-2xl">⭐</span>
          Featured
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          {featuredPosts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              author={post.data.author}
              tags={post.data.tags}
              category={post.data.category}
              slug={post.slug}
              image={post.data.image}
              featured={true}
            />
          ))}
        </div>
      </section>
    )}

    <section>
      <h2 class="text-2xl font-bold mb-6">Latest Posts</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {regularPosts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            author={post.data.author}
            tags={post.data.tags}
            category={post.data.category}
            slug={post.slug}
            image={post.data.image}
            featured={false}
          />
        ))}
      </div>
    </section>

    {sortedPosts.length === 0 && (
      <div class="text-center py-12">
        <p class="text-claude-text-light">No posts yet, stay tuned...</p>
      </div>
    )}
  </div>
</Layout>
