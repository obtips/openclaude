---
import Layout from '../../layouts/Layout.astro';
import { getEntry } from 'astro:content';

export const prerender = true;

const aboutPage = await getEntry('pages-en', 'about');
const Content = aboutPage ? (await aboutPage.render()).Content : null;

const title = aboutPage?.data?.title || 'About OpenClaude';
const description = aboutPage?.data?.description || 'Building a blazing-fast, minimal, and beautiful modern documentation and blog framework.';
---

<Layout title={title} description={description} lang="en">
  <div class="bg-claude-warm py-12 md:py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-claude-text mb-6">{title}</h1>
      <p class="text-xl text-claude-text-light max-w-2xl mx-auto">
        {description}
      </p>
    </div>
  </div>
  
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="prose prose-lg max-w-none text-gray-700">
      {Content ? <Content /> : <p>About page content not found.</p>}
    </div>
  </div>
</Layout>
