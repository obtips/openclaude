---
import AdminLayout from '../../components/admin/AdminLayout.astro'
---

<AdminLayout title="管理后台">
  <div id="admin-root"></div>
</AdminLayout>

<style>
  #admin-root {
    @apply min-h-screen;
  }
</style>

<script is:inline>
  (async () => {
    const React = await import('https://esm.sh/react@18')
    const { createRoot } = await import('https://esm.sh/react-dom@18/client')

    const API_BASE = '/api'

    const initialState = {
      view: 'login',
      posts: [],
      tutorials: [],
      contentType: 'blog',
      enableEnglish: true,
      error: '',
      user: null,
    }

    function AdminApp() {
      const [state, setState] = React.useState(initialState)

      const fetchWithAuth = async (url, options = {}) => {
        return fetch(url, {
          ...options,
          credentials: 'same-origin',
        })
      }

      // 检查登录状态
      React.useEffect(() => {
        checkLogin(true)
      }, [])

      const checkLogin = async (isInitialCheck = false) => {
        try {
          const response = await fetchWithAuth(`${API_BASE}/auth/session`)
          if (response.ok) {
            const sessionData = await response.json()
            setState(prev => ({
              ...prev,
              view: isInitialCheck ? 'list' : prev.view,
              error: '',
              user: sessionData.user
            }))
            // 如果是初始检查或没有文章才加载文章列表
            if (isInitialCheck) {
              loadPosts()
            }
          } else if (response.status === 401) {
            setState({ ...initialState, view: 'login' })
          }
        } catch (e) {
          console.error('Auth check failed:', e)
          setState({ ...initialState, view: 'login' })
        }
      }

      const loadPosts = async () => {
        try {
          const response = await fetchWithAuth(`${API_BASE}/posts`)
          if (response.ok) {
            const posts = await response.json()
            setState(prev => ({ ...prev, posts }))
          }
        } catch (e) {
          console.error('Load posts failed:', e)
        }
      }

      const handleLogin = async () => {
        // 检测是否是生产环境
        const isProduction = window.location.hostname !== 'localhost' && window.location.hostname !== '127.0.0.1'

        if (isProduction) {
          // 生产环境：跳转到 GitHub OAuth
          window.location.href = '/api/auth/login'
        } else {
          // 本地开发：使用简单登录
          const response = await fetchWithAuth(`${API_BASE}/auth/login`, { method: 'POST' })
          if (response.ok) {
            await checkLogin()
          }
        }
      }

      const handleLogout = async () => {
        await fetchWithAuth(`${API_BASE}/auth/logout`, { method: 'POST' })
        setState({ ...initialState, view: 'login' })
      }

      const handleNew = () => {
        setState({ ...state, view: 'new', currentPost: undefined })
      }

      const handleEdit = async (slug) => {
        try {
          const listPost = state.posts.find(p => p.slug === slug) || state.tutorials.find(p => p.slug === slug)
          const typeParam = listPost?.contentType ? `?type=${listPost.contentType}` : ''
          const response = await fetchWithAuth(`${API_BASE}/posts/${slug}${typeParam}`)
          if (response.ok) {
            const post = await response.json()
            // IMPORTANT: GitHub single file `.raw` fetch DOES NOT return `sha`.
            // We must merge the `sha` that was fetched from the list endpoint!
            setState({ ...state, view: 'edit', currentPost: { ...post, sha: listPost?.sha, contentType: listPost?.contentType } })
          }
        } catch (e) {
          setState({ ...state, error: '加载文章失败' })
        }
      }

      const handleSave = async (post) => {
        const isNew = state.view === 'new'
        const slug = isNew ? post.slug : state.currentPost?.slug
        const targetType = post.contentType || state.contentType || 'blog'

        try {
          const url = `${API_BASE}/posts${isNew ? '' : '/' + slug}?type=${targetType}`
          const response = await fetchWithAuth(url, {
            method: isNew ? 'POST' : 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ...post, contentType: targetType, sha: state.currentPost?.sha }),
          })

          if (response.ok) {
            await checkLogin(false)
            await loadPosts() // 保存成功后重新拉取新鲜列表
            setState(prev => ({ ...prev, view: 'list' }))
            return true
          } else {
            setState(prev => ({ ...prev, error: '保存失败' }))
            return false
          }
        } catch (e) {
          setState(prev => ({ ...prev, error: '保存失败' }))
          return false
        }
      }

      const handleDelete = async (slug, sha, contentType) => {
        try {
          const typeParam = contentType ? `?type=${contentType}` : ''
          const response = await fetchWithAuth(`${API_BASE}/posts/${slug}${typeParam}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sha }),
          })

          if (response.ok) {
            setState({
              ...state,
              posts: state.posts.filter(p => p.slug !== slug),
            })
          } else {
            setState({ ...state, error: '删除失败' })
          }
        } catch (e) {
          setState({ ...state, error: '删除失败' })
        }
      }

      const handleCancel = () => {
        setState({ ...state, view: 'list' })
      }

      const switchContentType = (type) => {
        setState({ ...state, contentType: type })
      }

      // 登录组件
      const Login = () => {
        const isProduction = window.location.hostname !== 'localhost' && window.location.hostname !== '127.0.0.1'

        return React.createElement('div', {
          style: { minHeight: '100vh', display: 'flex', alignItems: 'center', justifyContent: 'center', padding: '24px', background: '#F5F1E8' }
        },
          React.createElement('div', { style: { width: '100%', maxWidth: '400px' } },
            React.createElement('div', { style: { textAlign: 'center', marginBottom: '40px' } },
              React.createElement('h1', { style: { fontSize: '26px', fontWeight: '600', color: '#1A1A1A', marginBottom: '6px' } }, 'OpenClaude'),
              React.createElement('p', { style: { fontSize: '14px', color: '#6B7280' } }, '管理后台登录')
            ),

            React.createElement('div', { style: { background: 'white', borderRadius: '16px', padding: '32px', boxShadow: '0 4px 6px -1px rgba(0, 0, 0, 0.1)' } },
              React.createElement('div', { style: { textAlign: 'center' } },
                React.createElement('button', {
                  onClick: handleLogin,
                  style: {
                    width: '100%',
                    padding: '12px',
                    background: '#D4A574',
                    color: 'white',
                    border: 'none',
                    borderRadius: '8px',
                    fontSize: '15px',
                    fontWeight: '500',
                    cursor: 'pointer',
                  }
                }, isProduction ? '使用 GitHub 登录' : '登录后台')
              )
            )
          )
        )
      }

      // 文章列表组件
      const PostList = ({ posts, onNew, onEdit, onDelete }) => {
        const [search, setSearch] = React.useState('')
        const [categoryFilter, setCategoryFilter] = React.useState('全部')
        const [deleteConfirm, setDeleteConfirm] = React.useState(null)

        const categories = ['全部', ...Array.from(new Set(posts.map(p => p.category)))]

        const filteredPosts = posts.filter(post => {
          const matchesType = !post.contentType || post.contentType === state.contentType
          const matchesSearch =
            post.title.toLowerCase().includes(search.toLowerCase()) ||
            post.description.toLowerCase().includes(search.toLowerCase())
          const matchesCategory = categoryFilter === '全部' || post.category === categoryFilter
          return matchesType && matchesSearch && matchesCategory
        })

        const getStatusStyle = (post) => {
          if (post.draft) return { background: '#F3F4F6', color: '#6B7280', text: '草稿' }
          if (post.featured) return { background: '#FEF3C7', color: '#D97706', text: '精选' }
          return { background: '#D1FAE5', color: '#059669', text: '已发布' }
        }

        return React.createElement('div', {
          style: { maxWidth: '1200px', margin: '0 auto', padding: '32px 20px' }
        },
          // 顶部导航栏
          React.createElement('div', { style: { background: 'white', borderRadius: '12px', padding: '16px 24px', marginBottom: '24px', border: '1px solid #E5E7EB', display: 'flex', justifyContent: 'space-between', alignItems: 'center' } },
            React.createElement('div', { style: { display: 'flex', alignItems: 'center', gap: '24px' } },
              React.createElement('a', {
                href: '/',
                style: { textDecoration: 'none', color: '#6B7280', fontSize: '14px', display: 'flex', alignItems: 'center', gap: '6px' }
              }, '\u2190 返回首页'),
              React.createElement('div', { style: { display: 'flex', flexDirection: 'column', gap: '6px' } },
                React.createElement('div', { style: { display: 'flex', gap: '6px', alignItems: 'center' } },
                  React.createElement('span', { style: { fontSize: '12px', color: '#9CA3AF', width: '28px' } }, '中文'),
                  React.createElement('button', { onClick: () => switchContentType('blog'), style: { padding: '6px 14px', background: state.contentType === 'blog' ? '#D4A574' : 'white', color: state.contentType === 'blog' ? 'white' : '#374151', border: state.contentType === 'blog' ? 'none' : '1px solid #E5E7EB', borderRadius: '6px', fontSize: '13px', fontWeight: '500', cursor: 'pointer' } }, '博客'),
                  React.createElement('button', { onClick: () => switchContentType('tutorial'), style: { padding: '6px 14px', background: state.contentType === 'tutorial' ? '#D4A574' : 'white', color: state.contentType === 'tutorial' ? 'white' : '#374151', border: state.contentType === 'tutorial' ? 'none' : '1px solid #E5E7EB', borderRadius: '6px', fontSize: '13px', fontWeight: '500', cursor: 'pointer' } }, '教程'),
                  React.createElement('button', { onClick: () => switchContentType('pages'), style: { padding: '6px 14px', background: state.contentType === 'pages' ? '#D4A574' : 'white', color: state.contentType === 'pages' ? 'white' : '#374151', border: state.contentType === 'pages' ? 'none' : '1px solid #E5E7EB', borderRadius: '6px', fontSize: '13px', fontWeight: '500', cursor: 'pointer' } }, '单页')
                ),
                React.createElement('div', { style: { display: 'flex', gap: '6px', alignItems: 'center' } },
                  React.createElement('span', { style: { fontSize: '12px', color: '#9CA3AF', width: '28px' } }, 'EN'),
                  React.createElement('button', { onClick: () => switchContentType('blog-en'), style: { padding: '6px 14px', background: state.contentType === 'blog-en' ? '#D4A574' : 'white', color: state.contentType === 'blog-en' ? 'white' : '#374151', border: state.contentType === 'blog-en' ? 'none' : '1px solid #E5E7EB', borderRadius: '6px', fontSize: '13px', fontWeight: '500', cursor: 'pointer' } }, '博客'),
                  React.createElement('button', { onClick: () => switchContentType('tutorial-en'), style: { padding: '6px 14px', background: state.contentType === 'tutorial-en' ? '#D4A574' : 'white', color: state.contentType === 'tutorial-en' ? 'white' : '#374151', border: state.contentType === 'tutorial-en' ? 'none' : '1px solid #E5E7EB', borderRadius: '6px', fontSize: '13px', fontWeight: '500', cursor: 'pointer' } }, '教程'),
                  React.createElement('button', { onClick: () => switchContentType('pages-en'), style: { padding: '6px 14px', background: state.contentType === 'pages-en' ? '#D4A574' : 'white', color: state.contentType === 'pages-en' ? 'white' : '#374151', border: state.contentType === 'pages-en' ? 'none' : '1px solid #E5E7EB', borderRadius: '6px', fontSize: '13px', fontWeight: '500', cursor: 'pointer' } }, '单页')
                )
              )
            ),
            React.createElement('div', { style: { display: 'flex', alignItems: 'center', gap: '12px' } },
              React.createElement('button', {
                onClick: async () => {
                  const newVal = !state.enableEnglish;
                  const oldVal = state.enableEnglish;
                  
                  // 1. Optimistic UI update
                  setState(prev => ({ ...prev, enableEnglish: newVal }));
                  try { localStorage.setItem('oc_enableEnglish', JSON.stringify(newVal)); } catch {}
                  
                  try {
                    // 2. Fetch current file SHA
                    const getRes = await fetchWithAuth('/api/posts/settings?type=pages', { headers: { 'Cache-Control': 'no-store' } });
                    const getData = await getRes.json();
                    const sha = getData.sha;
                    
                    if (!sha) {
                      throw new Error('获取 settings.json 的 SHA 失败');
                    }
                    
                    // 3. Update file
                    const content = JSON.stringify({ enableEnglish: newVal }, null, 2) + '\n';
                    const putRes = await fetchWithAuth('/api/posts/settings', {
                      method: 'PUT',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ content, sha, enableEnglish: newVal })
                    });
                    
                    if (!putRes.ok) {
                      const errData = await putRes.json();
                      throw new Error(errData.error || '保存设置失败');
                    }
                    
                    // console.log('Successfully toggled English mode to:', newVal);
                  } catch(e) { 
                    console.error('Toggle failed:', e); 
                    alert('切换失败: ' + e.message + '。状态已恢复，请刷新页面重试。');
                    // 4. Revert state on failure
                    setState(prev => ({ ...prev, enableEnglish: oldVal }));
                    try { localStorage.setItem('oc_enableEnglish', JSON.stringify(oldVal)); } catch {}
                  }
                },
                style: {
                  padding: '6px 12px',
                  background: state.enableEnglish ? '#D4A574' : '#E5E7EB',
                  color: state.enableEnglish ? 'white' : '#6B7280',
                  border: 'none',
                  borderRadius: '6px',
                  fontSize: '12px',
                  cursor: 'pointer',
                  transition: 'all 0.2s',
                }
              }, state.enableEnglish ? '🌐 EN ✓' : '🌐 EN ✗'),
              React.createElement('span', { style: { fontSize: '14px', color: '#6B7280' } }, `${posts.length} 篇`),
              React.createElement('button', {
                onClick: handleLogout,
                style: { padding: '8px 16px', background: 'white', border: '1px solid #E5E7EB', borderRadius: '6px', fontSize: '14px', cursor: 'pointer' }
              }, '退出'),
              React.createElement('button', {
                onClick: onNew,
                style: { padding: '10px 20px', background: '#D4A574', color: 'white', border: 'none', borderRadius: '8px', fontSize: '14px', fontWeight: '500', cursor: 'pointer' }
              }, '+ 新建')
            )
          ),

          // 标题
          React.createElement('div', { style: { marginBottom: '24px' } },
            React.createElement('h1', { style: { fontSize: '28px', fontWeight: '600', color: '#1A1A1A', marginBottom: '4px' } },
              state.contentType === 'blog' ? '博客文章' : '教程文档'
            ),
            React.createElement('p', { style: { fontSize: '14px', color: '#6B7280' } }, '管理您的网站内容')
          ),

          // 搜索和筛选
          React.createElement('div', { style: { display: 'flex', gap: '12px', marginBottom: '24px' } },
            React.createElement('input', {
              type: 'text',
              placeholder: '搜索文章...',
              value: search,
              onChange: (e) => setSearch(e.target.value),
              style: { flex: 1, padding: '10px 14px', border: '1px solid #E5E7EB', borderRadius: '8px', fontSize: '14px' }
            }),
            React.createElement('select', {
              value: categoryFilter,
              onChange: (e) => setCategoryFilter(e.target.value),
              style: { padding: '10px 14px', border: '1px solid #E5E7EB', borderRadius: '8px', fontSize: '14px', background: 'white', minWidth: '120px' }
            }, categories.map(cat =>
              React.createElement('option', { key: cat, value: cat }, cat)
            ))
          ),

          // 文章列表
          filteredPosts.length === 0
            ? React.createElement('div', { style: { textAlign: 'center', padding: '60px 20px', color: '#9CA3AF' } },
                React.createElement('p', { style: { fontSize: '16px' } }, posts.length === 0 ? '暂无文章' : '没有匹配的文章')
              )
            : React.createElement('div', { style: { background: 'white', borderRadius: '12px', border: '1px solid #E5E7EB', overflow: 'hidden' } },
              React.createElement('table', { style: { width: '100%', borderCollapse: 'collapse' } },
                React.createElement('thead', null,
                  React.createElement('tr', { style: { borderBottom: '1px solid #E5E7EB', background: '#F9FAFB' } },
                    React.createElement('th', { style: { padding: '14px 20px', textAlign: 'left', fontSize: '12px', fontWeight: '600', color: '#6B7280', textTransform: 'uppercase', letterSpacing: '0.5px' } }, '标题'),
                    React.createElement('th', { style: { padding: '14px 20px', textAlign: 'left', fontSize: '12px', fontWeight: '600', color: '#6B7280', textTransform: 'uppercase', letterSpacing: '0.5px' } }, '分类'),
                    React.createElement('th', { style: { padding: '14px 20px', textAlign: 'left', fontSize: '12px', fontWeight: '600', color: '#6B7280', textTransform: 'uppercase', letterSpacing: '0.5px' } }, '状态'),
                    React.createElement('th', { style: { padding: '14px 20px', textAlign: 'left', fontSize: '12px', fontWeight: '600', color: '#6B7280', textTransform: 'uppercase', letterSpacing: '0.5px' } }, '日期'),
                    React.createElement('th', { style: { padding: '14px 20px', textAlign: 'right', fontSize: '12px', fontWeight: '600', color: '#6B7280', textTransform: 'uppercase', letterSpacing: '0.5px' } }, '操作')
                  )
                ),
                React.createElement('tbody', null,
                  filteredPosts.map((post, index) => {
                    const status = getStatusStyle(post)
                    return React.createElement('tr', {
                      key: post.slug,
                      style: { borderBottom: index < filteredPosts.length - 1 ? '1px solid #E5E7EB' : null }
                    },
                      React.createElement('td', { style: { padding: '16px 20px' } },
                        React.createElement('div', { style: { fontWeight: '500', color: '#1A1A1A', marginBottom: '4px' } }, post.title),
                        React.createElement('div', { style: { fontSize: '13px', color: '#6B7280', marginBottom: '4px', maxWidth: '400px', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' } }, post.description),
                        React.createElement('div', { style: { fontSize: '12px', color: '#9CA3AF', fontFamily: 'monospace' } }, `/${post.slug}`)
                      ),
                      React.createElement('td', { style: { padding: '16px 20px' } },
                        React.createElement('span', { style: { padding: '4px 10px', fontSize: '12px', fontWeight: '500', borderRadius: '12px', background: '#DBEAFE', color: '#1D4ED8' } }, post.category)
                      ),
                      React.createElement('td', { style: { padding: '16px 20px' } },
                        React.createElement('span', { style: { padding: '4px 10px', fontSize: '12px', fontWeight: '500', borderRadius: '12px', background: status.background, color: status.color } }, status.text)
                      ),
                      React.createElement('td', { style: { padding: '16px 20px', fontSize: '14px', color: '#6B7280' } },
                        new Date(post.date).toLocaleDateString('zh-CN')
                      ),
                      React.createElement('td', { style: { padding: '16px 20px', textAlign: 'right' } },
                        React.createElement('a', {
                          href: (() => { const t = post.contentType || state.contentType; if (t === 'blog') return `/blog/${post.slug}`; if (t === 'blog-en') return `/en/blog/${post.slug}`; if (t === 'pages') return `/${post.slug}/`; if (t === 'pages-en') return `/en/${post.slug}/`; if (t === 'tutorial-en') return `/en/tutorial/${post.slug}`; return `/tutorial/${post.slug}`; })(),
                          target: '_blank',
                          style: { padding: '6px 14px', background: 'transparent', border: 'none', color: '#6B7280', fontSize: '14px', cursor: 'pointer', borderRadius: '6px', marginRight: '4px', textDecoration: 'none' }
                        }, '查看'),
                        React.createElement('button', {
                          onClick: () => onEdit(post.slug),
                          style: { padding: '6px 14px', background: 'transparent', border: 'none', color: '#D4A574', fontSize: '14px', fontWeight: '500', cursor: 'pointer', borderRadius: '6px' }
                        }, '编辑'),
                        React.createElement('button', {
                          onClick: () => post.sha && onDelete(post.slug, post.sha, post.contentType),
                          style: { padding: '6px 14px', background: 'transparent', border: 'none', color: deleteConfirm === post.slug ? '#DC2626' : '#9CA3AF', fontSize: '14px', cursor: 'pointer', borderRadius: '6px', marginLeft: '8px' }
                        }, deleteConfirm === post.slug ? '确认?' : '删除')
                      )
                    )
                  })
                )
              )
            )
        )
      }

      // 内容类型标签映射
      const contentTypeLabels = {
        blog: '中文 · 博客', 'blog-en': 'EN · Blog',
        tutorial: '中文 · 教程', 'tutorial-en': 'EN · Tutorial',
        pages: '中文 · 单页', 'pages-en': 'EN · Page'
      }

      // 编辑器组件
      const PostEditor = ({ initialPost, onSave, onCancel, isNew, contentType }) => {
        const isBlog = contentType === 'blog' || contentType === 'blog-en'
        const isTutorial = contentType === 'tutorial' || contentType === 'tutorial-en'
        const isPage = contentType === 'pages' || contentType === 'pages-en'

        const [title, setTitle] = React.useState(initialPost?.title || '')
        const [description, setDescription] = React.useState(initialPost?.description || '')
        const [content, setContent] = React.useState(initialPost?.content || '')
        const [author, setAuthor] = React.useState(initialPost?.author || 'OpenClaude Team')
        const [tags, setTags] = React.useState(initialPost?.tags?.join(', ') || '')
        const [category, setCategory] = React.useState(initialPost?.category || '技术')
        const [difficulty, setDifficulty] = React.useState(initialPost?.difficulty || 'beginner')
        const [draft, setDraft] = React.useState(initialPost?.draft || false)
        const [featured, setFeatured] = React.useState(initialPost?.featured || false)
        const [image, setImage] = React.useState(initialPost?.image || '')
        const [slug, setSlug] = React.useState(initialPost?.slug || '')
        const [saving, setSaving] = React.useState(false)
        const [error, setError] = React.useState('')

        const categories = contentType?.includes('en') ? ['Tech', 'Announcement', 'Tutorial', 'Product', 'Community', 'AI', 'Dev'] : ['技术', '公告', '教程', '产品', '社区', 'AI', '开发']
        const difficultyOptions = [{ value: 'beginner', label: '入门', labelEn: 'Beginner' }, { value: 'intermediate', label: '进阶', labelEn: 'Intermediate' }, { value: 'advanced', label: '高级', labelEn: 'Advanced' }]

        const handleSave = async () => {
          if (!title.trim() || !description.trim()) {
            setError('标题和描述不能为空')
            return
          }
          setSaving(true)
          setError('')

          const post = { title, description, date: initialPost?.date || new Date().toISOString(), content }
          if (isBlog) {
            Object.assign(post, { author, tags: tags.split(',').map(t => t.trim()).filter(t => t), category, draft, featured, image: image || undefined })
          } else if (isTutorial) {
            Object.assign(post, { author, tags: tags.split(',').map(t => t.trim()).filter(t => t), difficulty, draft })
          }
          if ((isNew || slug !== initialPost?.slug) && slug) { post.slug = slug }

          const success = await onSave(post, initialPost?.sha)
          if (!success) setError('保存失败')
          setSaving(false)
        }

        return React.createElement('div', { style: { maxWidth: '800px', margin: '0 auto', padding: '32px 20px' } },
          // 头部
          React.createElement('div', { style: { display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '24px' } },
            React.createElement('div', null,
              React.createElement('a', {
                href: '/admin',
                style: { textDecoration: 'none', color: '#6B7280', fontSize: '14px', display: 'inline-flex', alignItems: 'center', gap: '4px', marginBottom: '8px' }
              }, '\u2190 返回列表'),
              React.createElement('h1', { style: { fontSize: '24px', fontWeight: '600', color: '#1A1A1A' } }, isNew ? '新建文章' : '编辑文章'),
              React.createElement('p', { style: { fontSize: '13px', color: '#D4A574', marginTop: '4px', fontWeight: '500' } }, `📝 ${contentTypeLabels[contentType] || contentType}`),
              !isNew && React.createElement('p', { style: { fontSize: '14px', color: '#9CA3AF', marginTop: '2px' } }, `/${initialPost?.slug}`)
            ),
            React.createElement('div', { style: { display: 'flex', gap: '8px' } },
              React.createElement('button', {
                onClick: onCancel,
                style: { padding: '8px 16px', background: 'white', border: '1px solid #E5E7EB', borderRadius: '6px', fontSize: '14px', cursor: 'pointer' }
              }, '取消'),
              React.createElement('button', {
                onClick: handleSave,
                disabled: saving,
                style: { padding: '8px 20px', background: '#D4A574', color: 'white', border: 'none', borderRadius: '6px', fontSize: '14px', fontWeight: '500', cursor: saving ? 'not-allowed' : 'pointer', opacity: saving ? 0.6 : 1 }
              }, saving ? '保存中...' : '保存')
            )
          ),

          error && React.createElement('div', {
            style: { marginBottom: '20px', padding: '12px 16px', background: '#FEF2F2', borderRadius: '8px', fontSize: '14px', color: '#DC2626', border: '1px solid #FECACA' }
          }, error),

          // 编辑表单
          React.createElement('div', { style: { display: 'flex', flexDirection: 'column', gap: '16px' } },
            // 基本信息
            React.createElement('div', { style: { background: 'white', borderRadius: '12px', padding: '20px', border: '1px solid #E5E7EB' } },
              React.createElement('div', { style: { display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '16px' } },
                React.createElement('div', null,
                  React.createElement('label', { style: { display: 'block', fontSize: '13px', fontWeight: '500', color: '#374151', marginBottom: '6px' } }, 'URL Slug'),
                  React.createElement('input', {
                    type: 'text',
                    value: slug,
                    onChange: (e) => setSlug(e.target.value),
                    placeholder: 'your-post-slug',
                    style: { width: '100%', padding: '10px 14px', border: '1px solid #E5E7EB', borderRadius: '8px', fontSize: '13px', boxSizing: 'border-box', fontFamily: 'monospace' }
                  })
                ),
                React.createElement('div', null,
                  React.createElement('label', { style: { display: 'block', fontSize: '13px', fontWeight: '500', color: '#374151', marginBottom: '6px' } }, '作者'),
                  React.createElement('input', {
                    type: 'text',
                    value: author,
                    onChange: (e) => setAuthor(e.target.value),
                    style: { width: '100%', padding: '10px 14px', border: '1px solid #E5E7EB', borderRadius: '8px', fontSize: '14px', boxSizing: 'border-box' }
                  })
                )
              ),

              React.createElement('div', null,
                React.createElement('label', { style: { display: 'block', fontSize: '13px', fontWeight: '500', color: '#374151', marginBottom: '6px' } }, '标题 *'),
                React.createElement('input', {
                  type: 'text',
                  value: title,
                  onChange: (e) => setTitle(e.target.value),
                  placeholder: '文章标题',
                  required: true,
                  style: { width: '100%', padding: '10px 14px', border: '1px solid #E5E7EB', borderRadius: '8px', fontSize: '16px', fontWeight: '500', boxSizing: 'border-box' }
                })
              ),

              React.createElement('div', null,
                React.createElement('label', { style: { display: 'block', fontSize: '13px', fontWeight: '500', color: '#374151', marginBottom: '6px' } }, '描述 *'),
                React.createElement('textarea', {
                  value: description,
                  onChange: (e) => setDescription(e.target.value),
                  placeholder: '简短描述文章内容',
                  rows: 2,
                  required: true,
                  style: { width: '100%', padding: '10px 14px', border: '1px solid #E5E7EB', borderRadius: '8px', fontSize: '14px', boxSizing: 'border-box', resize: 'vertical', minHeight: '60px' }
                })
              ),

              // 博客：分类 + 标签
              isBlog && React.createElement('div', { style: { display: 'grid', gridTemplateColumns: '1fr 2fr', gap: '16px' } },
                React.createElement('div', null,
                  React.createElement('label', { style: { display: 'block', fontSize: '13px', fontWeight: '500', color: '#374151', marginBottom: '6px' } }, '分类'),
                  React.createElement('select', {
                    value: category,
                    onChange: (e) => setCategory(e.target.value),
                    style: { width: '100%', padding: '10px 14px', border: '1px solid #E5E7EB', borderRadius: '8px', fontSize: '14px', boxSizing: 'border-box', background: 'white' }
                  }, categories.map(cat =>
                    React.createElement('option', { key: cat, value: cat }, cat)
                  ))
                ),
                React.createElement('div', null,
                  React.createElement('label', { style: { display: 'block', fontSize: '13px', fontWeight: '500', color: '#374151', marginBottom: '6px' } }, '标签'),
                  React.createElement('input', {
                    type: 'text', value: tags, onChange: (e) => setTags(e.target.value),
                    placeholder: 'React, JavaScript',
                    style: { width: '100%', padding: '10px 14px', border: '1px solid #E5E7EB', borderRadius: '8px', fontSize: '14px', boxSizing: 'border-box' }
                  })
                )
              ),

              // 教程：难度等级 + 标签
              isTutorial && React.createElement('div', { style: { display: 'grid', gridTemplateColumns: '1fr 2fr', gap: '16px' } },
                React.createElement('div', null,
                  React.createElement('label', { style: { display: 'block', fontSize: '13px', fontWeight: '500', color: '#374151', marginBottom: '6px' } }, '难度等级'),
                  React.createElement('select', {
                    value: difficulty,
                    onChange: (e) => setDifficulty(e.target.value),
                    style: { width: '100%', padding: '10px 14px', border: '1px solid #E5E7EB', borderRadius: '8px', fontSize: '14px', boxSizing: 'border-box', background: 'white' }
                  }, difficultyOptions.map(opt =>
                    React.createElement('option', { key: opt.value, value: opt.value }, contentType?.includes('en') ? opt.labelEn : opt.label)
                  ))
                ),
                React.createElement('div', null,
                  React.createElement('label', { style: { display: 'block', fontSize: '13px', fontWeight: '500', color: '#374151', marginBottom: '6px' } }, '标签'),
                  React.createElement('input', {
                    type: 'text', value: tags, onChange: (e) => setTags(e.target.value),
                    placeholder: 'Claude, AI',
                    style: { width: '100%', padding: '10px 14px', border: '1px solid #E5E7EB', borderRadius: '8px', fontSize: '14px', boxSizing: 'border-box' }
                  })
                )
              ),

              // 选项行（博客和教程）
              !isPage && React.createElement('div', { style: { display: 'flex', gap: '24px', paddingTop: '8px' } },
                React.createElement('label', { style: { display: 'flex', alignItems: 'center', gap: '8px', fontSize: '14px', color: '#374151', cursor: 'pointer' } },
                  React.createElement('input', { type: 'checkbox', checked: draft, onChange: (e) => setDraft(e.target.checked), style: { width: '16px', height: '16px' } }),
                  '草稿'
                ),
                isBlog && React.createElement('label', { style: { display: 'flex', alignItems: 'center', gap: '8px', fontSize: '14px', color: '#374151', cursor: 'pointer' } },
                  React.createElement('input', { type: 'checkbox', checked: featured, onChange: (e) => setFeatured(e.target.checked), style: { width: '16px', height: '16px' } }),
                  '精选'
                )
              )
            ),

            // Markdown 内容
            React.createElement('div', { style: { background: 'white', borderRadius: '12px', padding: '20px', border: '1px solid #E5E7EB' } },
              React.createElement('label', { style: { display: 'block', fontSize: '13px', fontWeight: '500', color: '#374151', marginBottom: '6px' } }, '文章内容 (Markdown)'),
              React.createElement('textarea', {
                value: content,
                onChange: (e) => setContent(e.target.value),
                placeholder: '# 开始写作...\n\n支持 **Markdown** 语法',
                rows: 18,
                style: { width: '100%', padding: '10px 14px', border: '1px solid #E5E7EB', borderRadius: '8px', fontSize: '13px', fontFamily: 'monospace', lineHeight: '1.6', minHeight: '400px', resize: 'vertical', boxSizing: 'border-box' }
              })
            )
          )
        )
      }

      // 渲染
      if (state.view === 'login') {
        return React.createElement(Login)
      }

      if (state.view === 'list') {
        return React.createElement(PostList, {
          posts: state.posts,
          onNew: handleNew,
          onEdit: handleEdit,
          onDelete: handleDelete,
        })
      }

      return React.createElement(PostEditor, {
        initialPost: state.currentPost,
        isNew: state.view === 'new',
        onSave: handleSave,
        onCancel: handleCancel,
        contentType: state.contentType,
      })
    }

    const container = document.getElementById('admin-root')
    if (container) {
      const root = createRoot(container)
      root.render(React.createElement(AdminApp))
    }
  })()
</script>
