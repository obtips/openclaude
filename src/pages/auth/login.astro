---
// 重定向到 GitHub OAuth
const githubClientId = import.meta.env.GITHUB_CLIENT_ID || ''
const redirectUri = new URL(Astro.request.url).origin + '/api/auth/callback'

if (!githubClientId) {
  return new Response('GITHUB_CLIENT_ID not configured', { status: 500 })
}

const params = new URLSearchParams({
  client_id: githubClientId,
  redirect_uri: redirectUri,
  scope: 'read:user user:email',
  state: crypto.randomUUID(),
})

const githubUrl = `https://github.com/login/oauth/authorize?${params}`

return Astro.redirect(githubUrl)
---
