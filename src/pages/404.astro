---
import Layout from '../layouts/Layout.astro'
---

<Layout title="404 - 页面未找到" description="抱歉，您访问的页面不存在">
  <div class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <h1 class="text-6xl md:text-8xl font-bold text-claude-accent mb-4">404</h1>
      <h2 class="text-2xl md:text-3xl font-semibold mb-4">页面未找到</h2>
      <p class="text-claude-text-light mb-8">
        抱歉，您访问的页面不存在或已被移动。
      </p>
      <a href="/" class="btn-primary">
        返回首页
      </a>
    </div>
  </div>
</Layout>
