---
interface Props {
  lang?: string
}

const { lang = 'zh' } = Astro.props

const nav = {
  zh: {
    home: '首页',
    tutorial: '教程',
    blog: '博客',
    about: '关于',
  },
  en: {
    home: 'Home',
    tutorial: 'Tutorials',
    blog: 'Blog',
    about: 'About',
  }
}

const t = nav[lang as keyof typeof nav]
const currentPath = Astro.url.pathname
const langPrefix = lang === 'en' ? '/en' : ''
const basePath = currentPath.replace(/^\/en/, '')
const switchPath = lang === 'zh' ? `/en${basePath || '/'}` : (basePath || '/')
---

<header class="sticky top-0 z-50 bg-claude-cream/90 backdrop-blur-sm border-b border-claude-border">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={lang === 'en' ? '/en' : '/'} class="flex items-center gap-2 hover:opacity-70 transition-opacity">
        <svg class="w-7 h-7" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="8" fill="#D4A574"/>
          <path d="M20 8V19" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
          <circle cx="15" cy="21" r="3.5" stroke="white" stroke-width="2" fill="none"/>
          <path d="M20 8L24 7V12L20 13" stroke="white" stroke-width="2" stroke-linejoin="round" fill="white"/>
        </svg>
        <span class="font-semibold text-lg tracking-tight">OpenClaude</span>
      </a>

      <!-- 导航 -->
      <nav class="hidden md:flex items-center gap-8">
        <a href={lang === 'en' ? '/en' : '/'} class="text-claude-text-light hover:text-claude-text transition-colors text-sm">
          {t.home}
        </a>
        <a href={`${langPrefix}/tutorial/`} class="text-claude-text-light hover:text-claude-text transition-colors text-sm">
          {t.tutorial}
        </a>
        <a href={`${langPrefix}/blog/`} class="text-claude-text-light hover:text-claude-text transition-colors text-sm">
          {t.blog}
        </a>
        <a href={`${langPrefix}/about`} class="text-claude-text-light hover:text-claude-text transition-colors text-sm">
          {t.about}
        </a>
      </nav>

      <!-- 移动端控件 -->
      <div class="flex items-center gap-2 md:hidden">
        <a
          id="lang-switch-mobile"
          href={switchPath}
          class="!hidden flex items-center justify-center w-9 h-9 rounded-lg bg-white border border-claude-border transition-colors text-sm"
          title={lang === 'zh' ? 'Switch to English' : '切换到中文'}
          style="display: none;"
        >
          {lang === 'zh' ? 'EN' : '中'}
        </a>
        <button
          id="mobile-menu-btn"
          class="flex items-center justify-center w-9 h-9 rounded-lg bg-white border border-claude-border transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <!-- 桌面端语言切换 -->
      <a
        id="lang-switch-desktop"
        href={switchPath}
        class="!hidden hidden md:flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-white border border-claude-border transition-all text-sm"
        title={lang === 'zh' ? 'Switch to English' : '切换到中文'}
        style="display: none;"
      >
        {lang === 'zh' ? 'EN' : '中文'}
      </a>
    </div>
  </div>

  <!-- 移动端菜单 -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-claude-border bg-claude-cream/95 backdrop-blur-sm">
    <nav class="flex flex-col py-4 px-4 gap-2">
      <a href={lang === 'en' ? '/en' : '/'} class="text-claude-text-light hover:text-claude-text transition-colors block py-2">
        {t.home}
      </a>
      <a href={`${langPrefix}/tutorial/`} class="text-claude-text-light hover:text-claude-text transition-colors block py-2">
        {t.tutorial}
      </a>
      <a href={`${langPrefix}/blog/`} class="text-claude-text-light hover:text-claude-text transition-colors block py-2">
        {t.blog}
      </a>
      <a href={`${langPrefix}/about`} class="text-claude-text-light hover:text-claude-text transition-colors block py-2">
        {t.about}
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const elDesktop = document.getElementById('lang-switch-desktop');
    const elMobile = document.getElementById('lang-switch-mobile');

    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIconPath = document.getElementById('menu-icon-path');
    let isMenuOpen = false;

    if (mobileBtn && mobileMenu && menuIconPath) {
      mobileBtn.addEventListener('click', () => {
        isMenuOpen = !isMenuOpen;
        if (isMenuOpen) {
          mobileMenu.classList.remove('hidden');
          menuIconPath.setAttribute('d', 'M6 18L18 6M6 6l12 12');
        } else {
          mobileMenu.classList.add('hidden');
          menuIconPath.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
        }
      });
    }

    const applyState = (isEnabled) => {
      [elDesktop, elMobile].forEach(el => {
        if (!el) return;
        if (isEnabled) {
          el.classList.remove('!hidden');
          el.style.display = '';
        } else {
          el.classList.add('!hidden');
        }
      });
    };

    applyState(false);

    window.addEventListener('oc_lang_toggled', (e) => {
       applyState(e.detail.isEnabled);
    });

    fetch('/api/posts/settings?t=' + Date.now(), { cache: 'no-store' })
      .then(res => res.ok ? res.json() : { enableEnglish: true })
      .then(data => {
        const isEnabled = data.enableEnglish !== false;
        applyState(isEnabled);
      })
      .catch(() => {
        applyState(false);
      });
  });
</script>
