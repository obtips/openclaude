---
interface Props {
  title?: string
}

const { title = '管理后台' } = Astro.props
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - OpenClaude Admin</title>
  </head>
  <body class="bg-gray-50">
    <div id="app"></div>
    <slot />
  </body>
</html>

<style is:global>
  * {
    @apply box-border;
  }

  body {
    @apply m-0 font-sans;
  }
</style>
