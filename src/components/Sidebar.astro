---
import { getCollection } from 'astro:content'

interface Props {
  lang?: string
}

const { lang = 'zh' } = Astro.props
const collection = lang === 'en' ? 'tutorial-en' : 'tutorial'

const tutorials = await getCollection(collection, ({ data }) => {
  return data.draft !== true
})

// 按难度分组
const byDifficulty = tutorials.reduce((acc, tutorial) => {
  const diff = tutorial.data.difficulty || 'other'
  if (!acc[diff]) acc[diff] = []
  acc[diff].push(tutorial)
  return acc
}, {} as Record<string, typeof tutorials>)

const difficultyOrder = ['beginner', 'intermediate', 'advanced', 'other']
---

<aside class="sticky top-24 self-start">
  <div class="bg-white rounded-xl shadow-soft p-4">
    <h3 class="font-semibold mb-4 text-sm text-claude-text-light uppercase tracking-wider">
      {lang === 'zh' ? '教程目录' : 'Contents'}
    </h3>

    <nav class="space-y-4">
      {
        difficultyOrder.map(difficulty => {
          const items = byDifficulty[difficulty]
          if (!items || items.length === 0) return null

          const labels = {
            beginner: lang === 'zh' ? '入门' : 'Beginner',
            intermediate: lang === 'zh' ? '进阶' : 'Intermediate',
            advanced: lang === 'zh' ? '高级' : 'Advanced',
            other: lang === 'zh' ? '其他' : 'Other'
          }

          return (
            <div>
              <h4 class="text-xs font-semibold text-claude-accent mb-2">
                {labels[difficulty as keyof typeof labels]}
              </h4>
              <ul class="space-y-1">
                {items.map(item => (
                  <li>
                    <a
                      href={`/${lang === 'en' ? 'en/' : ''}tutorial/${item.slug}/`}
                      class={`block text-sm py-1 px-2 rounded transition-colors ${
                        Astro.url.pathname.endsWith(`/${item.slug}/`)
                          ? 'bg-claude-accent/10 text-claude-accent font-medium'
                          : 'text-claude-text-light hover:text-claude-text hover:bg-claude-warm'
                      }`}
                    >
                      {item.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        })
      }
    </nav>
  </div>
</aside>
