---
interface Props {
  lang?: string
}

const { lang = 'zh' } = Astro.props

const footer = {
  zh: {
    rights: '© 2025 OpenClaude. 保留所有权利。',
    madeWith: '用',
    astro: '构建',
  },
  en: {
    rights: '© 2025 OpenClaude. All rights reserved.',
    madeWith: 'Made with',
    astro: 'Built with',
  }
}

const t = footer[lang as keyof typeof footer]
const currentYear = new Date().getFullYear()
---

<footer class="border-t border-claude-border bg-claude-warm">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <!-- Logo & Tagline -->
      <div class="flex items-center gap-2">
        <svg class="w-6 h-6" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="8" fill="#D4A574"/>
          <path d="M20 8V19" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
          <circle cx="15" cy="21" r="3.5" stroke="white" stroke-width="2" fill="none"/>
          <path d="M20 8L24 7V12L20 13" stroke="white" stroke-width="2" stroke-linejoin="round" fill="white"/>
        </svg>
        <span class="text-claude-text-light text-sm">
          {t.madeWith} <a href="https://astro.build" target="_blank" class="text-claude-accent">Astro</a>
        </span>
      </div>

      <!-- 链接 -->
      <div class="flex items-center gap-4">
        <a
          href="https://github.com/openclaude"
          target="_blank"
          rel="noopener noreferrer"
          class="text-claude-text-light hover:text-claude-text transition-colors"
          title="GitHub"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
        </a>
        <a
          href="https://x.com/openclaude"
          target="_blank"
          rel="noopener noreferrer"
          class="text-claude-text-light hover:text-claude-text transition-colors"
          title="X (Twitter)"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      </div>

      <!-- 版权 -->
      <div class="flex items-center gap-3">
        <p class="text-claude-text-light text-sm">
          © {currentYear} OpenClaude
        </p>
        <a href="/admin/" class="text-claude-text-light/40 hover:text-claude-text-light text-xs transition-colors" title="管理后台">⚙</a>
      </div>
    </div>
  </div>
</footer>
