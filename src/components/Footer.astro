---
interface Props {
  lang?: string
}

const { lang = 'zh' } = Astro.props

const footer = {
  zh: {
    madeWith: '使用',
    astro: '构建',
  },
  en: {
    madeWith: 'Built with',
    astro: 'astro',
  }
}

const t = footer[lang as keyof typeof footer]
const currentYear = new Date().getFullYear()
---

<footer class="border-t border-claude-border bg-claude-warm">
  <!-- 康定斯基风格装饰线条 -->
  <div class="w-full h-px overflow-hidden">
    <div class="flex">
      <div class="h-px w-1/4" style="background-color: var(--kandinsky-yellow);"></div>
      <div class="h-px w-1/4" style="background-color: var(--kandinsky-blue);"></div>
      <div class="h-px w-1/4" style="background-color: var(--kandinsky-red);"></div>
      <div class="h-px w-1/4 bg-claude-border"></div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="8" fill="#D4A574"/>
          <path d="M20 8V19" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
          <circle cx="15" cy="21" r="3.5" stroke="white" stroke-width="2" fill="none"/>
          <path d="M20 8L24 7V12L20 13" stroke="white" stroke-width="2" stroke-linejoin="round" fill="white"/>
        </svg>
        <span class="text-claude-text-light text-sm">
          {t.madeWith} <a href="https://astro.build" target="_blank" class="text-claude-accent hover:opacity-70 transition-opacity">Astro</a>
        </span>
      </div>

      <!-- 版权 -->
      <div class="flex items-center gap-3">
        <p class="text-claude-text-light text-sm">
          © {currentYear} OpenClaude
        </p>
        <a href="/admin/" class="text-claude-text-light/40 hover:text-claude-text-light text-xs transition-colors" title="管理后台">管理</a>
      </div>
    </div>
  </div>
</footer>
