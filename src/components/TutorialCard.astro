---
interface Props {
  title: string
  description: string
  difficulty: 'beginner' | 'intermediate' | 'advanced'
  tags: string[]
  slug: string
  lang?: string
}

const {
  title,
  description,
  difficulty,
  tags,
  slug,
  lang = 'zh'
} = Astro.props

const difficultyLabels = {
  beginner: { zh: '入门', en: 'Beginner', color: 'bg-green-100 text-green-700' },
  intermediate: { zh: '进阶', en: 'Intermediate', color: 'bg-yellow-100 text-yellow-700' },
  advanced: { zh: '高级', en: 'Advanced', color: 'bg-red-100 text-red-700' },
}

const diffInfo = difficultyLabels[difficulty]
const label = diffInfo[lang as keyof typeof diffInfo]
const colorClass = diffInfo.color
const langPrefix = lang === 'en' ? '/en' : ''
---

<a href={`${langPrefix}/tutorial/${slug}/`} class="card group block hover:-translate-y-1 transition-transform">
  <div class="flex items-start justify-between mb-3">
    <h3 class="text-lg font-semibold group-hover:text-claude-accent transition-colors">
      {title}
    </h3>
  </div>

  <p class="text-claude-text-light text-sm mb-4 line-clamp-2">
    {description}
  </p>

  <div class="flex items-center gap-2 flex-wrap">
    <span class={`text-xs px-2 py-1 rounded-full ${colorClass}`}>
      {label}
    </span>
    {tags.slice(0, 2).map(tag => (
      <span class="text-xs px-2 py-1 rounded-full bg-claude-warm text-claude-text-light">
        {tag}
      </span>
    ))}
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
