# Giscus 评论系统配置
# 访问 https://giscus.app 获取这些值

# GitHub 仓库 (格式: username/repo)
GISCUS_REPO=YOUR_USERNAME/YOUR_REPO

# 仓库 ID
GISCUS_REPO_ID=R_kgDON...

# 讨论分类名称
GISCUS_CATEGORY=Announcements

# 分类 ID
GISCUS_CATEGORY_ID=DIC_kwDON...

# 评论系统启用
# 设置为 'true' 启用，'false' 禁用
GISCUS_ENABLED=true

# 管理后台 GitHub API 配置
# 访问 https://github.com/settings/tokens 创建 Personal Access Token
# 需要勾选 repo 权限

# GitHub Personal Access Token (可选，用于管理后台)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# GitHub 仓库信息
GITHUB_REPO_OWNER=your-username
GITHUB_REPO_NAME=your-repo-name
