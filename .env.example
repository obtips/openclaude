# =====================================================
# Giscus 评论系统配置
# 访问 https://giscus.app 获取这些值
# =====================================================

# GitHub 仓库 (格式: username/repo)
GISCUS_REPO=YOUR_USERNAME/YOUR_REPO

# 仓库 ID
GISCUS_REPO_ID=R_kgDON...

# 讨论分类名称
GISCUS_CATEGORY=Announcements

# 分类 ID
GISCUS_CATEGORY_ID=DIC_kwDON...

# 评论系统启用 (true/false)
GISCUS_ENABLED=true

# =====================================================
# GitHub OAuth 配置 (管理后台登录)
# 访问 https://github.com/settings/developers 创建 OAuth App
# =====================================================

# GitHub OAuth Client ID
GITHUB_CLIENT_ID=iv1234567890abcdef

# GitHub OAuth Client Secret
GITHUB_CLIENT_SECRET=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 回调 URL (本地开发)
# 在 OAuth App 设置中添加: http://localhost:4321/functions/api/auth/callback

# =====================================================
# GitHub API 配置 (文章管理)
# 访问 https://github.com/settings/tokens 创建 PAT
# 需要 repo 权限
# =====================================================

# GitHub Personal Access Token
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# GitHub 仓库信息
GITHUB_REPO_OWNER=your-username
GITHUB_REPO_NAME=your-repo-name
